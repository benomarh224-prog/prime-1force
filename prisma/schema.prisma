generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatar        String?
  role          String    @default("user")  /// "user" | "admin"
  emailVerified DateTime?
  weight        Float?
  height        Float?
  goal          String?   @default("lose_weight")
  level         String?   @default("beginner")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workouts      WorkoutSession[]
  favorites     Favorite[]
  chatMessages  ChatMessage[]
  workoutPrograms WorkoutProgram[]
  workoutScheduleDays WorkoutScheduleDay[]
  workoutCompletions WorkoutCompletion[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? /// @db.Text
  access_token      String? /// @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? /// @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workout {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("gym")
  difficulty  String   @default("intermediate")
  muscleGroup String?
  equipment   String?  @default("dumbbells")
  duration    Int?
  calories    Int?
  image       String?
  steps       String?   /// JSON array of step strings
  tips        String?   /// JSON array of tip strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  favorites   Favorite[]
}

model WorkoutSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  workoutId String?
  date      DateTime @default(now())
  duration  Int?
  calories  Int?
  notes     String?
  createdAt DateTime @default(now())
}

model WorkoutProgram {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  days        WorkoutScheduleDay[]
  completions WorkoutCompletion[]

  @@index([userId])
}

model WorkoutScheduleDay {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId   String
  program     WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      /// 0 = Sunday, 1 = Monday, ... 6 = Saturday
  splitTitle  String
  exercises   String?  /// JSON array of exercise or muscle group names
  notes       String?
  isRestDay   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completions WorkoutCompletion[]

  @@unique([userId, programId, dayOfWeek])
  @@index([userId])
  @@index([programId])
}

model WorkoutCompletion {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId     String
  program       WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  scheduleDayId String?
  scheduleDay   WorkoutScheduleDay? @relation(fields: [scheduleDayId], references: [id], onDelete: SetNull)
  date          DateTime
  dayOfWeek     Int
  splitTitle    String
  notes         String?
  completedAt   DateTime @default(now())

  @@unique([userId, programId, date])
  @@index([userId])
  @@index([programId])
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, workoutId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String
  content   String
  createdAt DateTime @default(now())
}

model Meal {
  id          String  @id @default(cuid())
  name        String
  category    String  @default("breakfast")
  calories    Int
  protein     Float?
  carbs       Float?
  fat         Float?
  description String?
  ingredients String?   /// JSON array of ingredient strings
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
